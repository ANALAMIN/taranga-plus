{
  "name": "taranga-plus",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "clean": "node -e \"const fs=require('fs');['dist','dist-electron','server.js'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.tarangaplus.app",
    "productName": "Taranga+",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.png",
      "artifactName": "Taranga+-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.14.3",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.18.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "idb": "^8.0.3",
    "lenis": "^1.3.23",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "shaka-player": "^5.1.10",
    "styled-components": "^6.4.2",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.21",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
