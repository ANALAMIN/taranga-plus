{
  // Root config: a no-op aggregator. `npm run lint` type-checks each
  // environment directly (tsc --noEmit -p tsconfig.<env>.json) so a single run
  // covers all of them WITHOUT cross-pollinating ambient globals. The old
  // single-config lumped Cloudflare's `KVNamespace`, Electron globals and Node
  // globals together, causing type-bleed into the renderer (e.g. apiClient had
  // to redeclare Window.electronAPI). The per-env configs below fix that.
  "files": [],
  "references": [
    { "path": "./tsconfig.renderer.json" },
    { "path": "./tsconfig.main.json" },
    { "path": "./tsconfig.worker.json" }
  ]
}
